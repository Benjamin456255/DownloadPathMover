<Window x:Class="DownloadMoverWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="系统文件夹路径迁移工具 — System Folder Mover"
        Width="640" Height="780"
        ResizeMode="CanResize"
        MinWidth="600" MinHeight="740"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush"              Color="#F0F2F5"/>
        <SolidColorBrush x:Key="CardBgBrush"          Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardBorderBrush"      Color="#E5E7EB"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#1F2937"/>
        <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#6B7280"/>
        <SolidColorBrush x:Key="TextMutedBrush"       Color="#9CA3AF"/>
        <SolidColorBrush x:Key="PrimaryBrush"         Color="#3B82F6"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush"    Color="#2563EB"/>
        <SolidColorBrush x:Key="SuccessBrush"         Color="#10B981"/>
        <SolidColorBrush x:Key="DangerBrush"          Color="#EF4444"/>
        <SolidColorBrush x:Key="WarningBrush"         Color="#F59E0B"/>
        <SolidColorBrush x:Key="LogBgBrush"           Color="#1E293B"/>
        <SolidColorBrush x:Key="LogFgBrush"           Color="#E2E8F0"/>
        <SolidColorBrush x:Key="LogInfoBrush"         Color="#94A3B8"/>
        <SolidColorBrush x:Key="LogSuccessBrush"      Color="#34D399"/>
        <SolidColorBrush x:Key="LogErrorBrush"        Color="#F87171"/>
        <SolidColorBrush x:Key="LogWarnBrush"         Color="#FBBF24"/>
        <SolidColorBrush x:Key="PathBgBrush"           Color="#F9FAFB"/>
        <SolidColorBrush x:Key="FooterBgBrush"        Color="#FEF2F2"/>
        <SolidColorBrush x:Key="FooterFgBrush"        Color="#EF4444"/>
        <SolidColorBrush x:Key="ProgressTrackBrush"    Color="#E5E7EB"/>
        <SolidColorBrush x:Key="CurrentPathBrush"     Color="#6B7280"/>
        <SolidColorBrush x:Key="TargetPathBrush"      Color="#2563EB"/>

        <!-- Buttons -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="8"
                                Background="{StaticResource PrimaryBrush}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="14,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{StaticResource SuccessBrush}" CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="14,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="8" Background="#EF4444">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="14,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ProgressBar -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{StaticResource ProgressTrackBrush}" CornerRadius="3">
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#6366F1" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LogRichTextBoxStyle" TargetType="RichTextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="{StaticResource LogBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource LogFgBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
    </Window.Resources>

    <!-- ==================================================================== -->
    <Grid x:Name="RootGrid" Margin="22,14,22,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="📁  系统文件夹路径迁移工具"
                   FontSize="17" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,2"/>
        <TextBlock Grid.Row="1" Text="将 Windows 用户文件夹一键迁移到指定盘符"
                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,10"/>

        <!-- 盘符 + 工具栏 -->
        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LblSection1" Text="🎯 目标盘符" FontSize="12" FontWeight="Bold"
                           Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="TxtDriveRoot" Grid.Column="1" Text="D:\"
                         FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Background="{StaticResource PathBgBrush}"
                         BorderBrush="#E5E7EB" BorderThickness="1"
                         Padding="8,4" VerticalContentAlignment="Center"
                         TextChanged="TxtDriveRoot_TextChanged"/>
                <Button x:Name="BtnBrowseDrive" Grid.Column="2" Content="✏️"
                        Style="{StaticResource SmallButtonStyle}" Width="36"
                        Click="BtnBrowseDrive_Click" Margin="6,0"/>
                <Button x:Name="BtnRefresh" Grid.Column="3" Content="🔄 刷新当前路径"
                        Style="{StaticResource SmallButtonStyle}"
                        Click="BtnRefreshPaths_Click"/>
            </Grid>
        </Border>

        <!-- 文件夹选择 + 当前/目标预览 -->
        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,6">
            <StackPanel>
                <TextBlock x:Name="LblSection2" Text="📂  选择要迁移的文件夹" FontSize="12" FontWeight="Bold"
                           Foreground="#64748B" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <CheckBox x:Name="ChkDownloads"  Content="📥  Downloads"   IsChecked="True" Margin="0,0,0,3"/>
                        <CheckBox x:Name="ChkDesktop"    Content="🖥️  Desktop"                    Margin="0,0,0,3"/>
                        <CheckBox x:Name="ChkDocuments"  Content="📄  Documents"                  Margin="0,0,0,3"/>
                        <CheckBox x:Name="ChkPictures"   Content="🖼️  Pictures"                   Margin="0,0,0,3"/>
                        <CheckBox x:Name="ChkMusic"      Content="🎵  Music"                      Margin="0,0,0,3"/>
                        <CheckBox x:Name="ChkVideos"     Content="🎬  Videos"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="TxtCurDownloads"  FontSize="10" Foreground="{StaticResource CurrentPathBrush}" Margin="0,0,0,3" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtCurDesktop"    FontSize="10" Foreground="{StaticResource CurrentPathBrush}" Margin="0,0,0,3" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtCurDocuments"  FontSize="10" Foreground="{StaticResource CurrentPathBrush}" Margin="0,0,0,3" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtCurPictures"   FontSize="10" Foreground="{StaticResource CurrentPathBrush}" Margin="0,0,0,3" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtCurMusic"      FontSize="10" Foreground="{StaticResource CurrentPathBrush}" Margin="0,0,0,3" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtCurVideos"     FontSize="10" Foreground="{StaticResource CurrentPathBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 选项 -->
        <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock x:Name="LblSection3" Text="⚙️  选项" FontSize="12" FontWeight="Bold"
                           Foreground="#64748B" Margin="0,0,0,4"/>
                <CheckBox x:Name="ChkMigrate"
                          Content="迁移已有文件到新路径（复制，不删除原文件）"/>
                <CheckBox x:Name="ChkCopyOnly"
                          Content="仅复制文件，不修改注册表（纯迁移模式）"
                          Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- 进度条 + 状态 -->
        <ProgressBar Grid.Row="5" x:Name="ProgressBar" Margin="0,0,0,2"/>
        <TextBlock Grid.Row="6" x:Name="TxtStatus" Text="就绪"
                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                   HorizontalAlignment="Center" Margin="0,2,0,6"/>

        <!-- 按钮行 1 -->
        <WrapPanel Grid.Row="7" HorizontalAlignment="Center" Margin="0,0,0,4">
            <Button x:Name="BtnApply" Content="🚀  一 键 修 改"
                    Style="{StaticResource PrimaryButtonStyle}" Width="140"
                    Click="BtnApply_Click" Margin="0,0,6,0"/>
            <Button x:Name="BtnRestore" Content="↩️  恢复默认"
                    Style="{StaticResource DangerButtonStyle}" Width="120"
                    Click="BtnRestore_Click" Margin="0,0,6,0"/>
            <Button x:Name="BtnUndo" Content="↩  撤销上次"
                    Style="{StaticResource SecondaryButtonStyle}" Width="110"
                    Click="BtnUndo_Click" IsEnabled="False"/>
        </WrapPanel>

        <!-- 按钮行 2 -->
        <WrapPanel Grid.Row="8" HorizontalAlignment="Center" Margin="0,0,0,6">
            <Button x:Name="BtnImport" Content="📥 导入配置"
                    Style="{StaticResource SmallButtonStyle}" Width="90"
                    Click="BtnImport_Click" Margin="0,0,6,0"/>
            <Button x:Name="BtnExport" Content="📤 导出配置"
                    Style="{StaticResource SmallButtonStyle}" Width="90"
                    Click="BtnExport_Click" Margin="0,0,6,0"/>
            <Button x:Name="BtnQuit" Content="退出"
                    Style="{StaticResource SmallButtonStyle}" Width="60"
                    Click="BtnQuit_Click"/>
        </WrapPanel>

        <!-- 日志 -->
        <TextBlock Grid.Row="9" x:Name="TxtLogToggle" Text="📋 操作日志 ▾"
                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                   Cursor="Hand" MouseLeftButtonDown="TxtLogToggle_Click"
                   HorizontalAlignment="Left" Margin="0,0,0,3"/>
        <RichTextBox Grid.Row="10" x:Name="LogBox" Style="{StaticResource LogRichTextBoxStyle}"
                     Height="120" Visibility="Collapsed"/>

        <!-- 底部 -->
        <Border Grid.Row="11" Background="{StaticResource FooterBgBrush}"
                CornerRadius="8" Padding="10,6" VerticalAlignment="Bottom">
            <Grid>
                <TextBlock Text="⚠️  修改注册表前请确认已备份重要数据"
                           FontSize="10" Foreground="{StaticResource FooterFgBrush}"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
